generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

model ModerationBan {
  id           BigInt    @id @default(autoincrement())
  guildId      String    @map("guild_id")
  userId       String    @map("user_id")
  username     String
  moderatorId  String?   @map("moderator_id")
  moderatorTag String?   @map("moderator_tag")
  reason       String
  permanent    Boolean   @default(true)
  bannedAt     DateTime  @default(now()) @map("banned_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by_id")

  @@index([guildId, bannedAt])
  @@index([guildId, userId, revokedAt])
  @@index([userId])
  @@map("houston_bot_moderation_bans")
}

model ModerationTimeout {
  id           BigInt    @id @default(autoincrement())
  guildId      String    @map("guild_id")
  userId       String    @map("user_id")
  username     String
  moderatorId  String?   @map("moderator_id")
  moderatorTag String?   @map("moderator_tag")
  reason       String
  duration     Int
  expiresAt    DateTime  @map("expires_at")
  appliedAt    DateTime  @default(now()) @map("applied_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by_id")

  @@index([guildId, appliedAt])
  @@index([guildId, expiresAt])
  @@index([userId])
  @@map("houston_bot_moderation_timeouts")
}

model ScheduledMessage {
  id             BigInt        @id @default(autoincrement())
  createdAt      DateTime      @default(now()) @map("created_at")
  guildId        String        @map("guild_id")
  channelId      String        @map("channel_id")
  messageContent String        @map("message_content")
  scheduleTime   DateTime      @map("schedule_time")
  status         MessageStatus @default(PENDING)
  title          String?
  messageUrl     String?       @map("message_url")
  imageUrl       String?       @map("image_url")
  reactions      String[]      @default([])

  @@map("houston_bot_scheduled_messages")
}

enum MessageStatus {
  PENDING
  SENT
  ERROR_SENDING
  ERROR_CHANNEL_NOT_FOUND
}

model Report {
  id              BigInt            @id @default(autoincrement())
  discordThreadId String            @unique @map("discord_thread_id")
  discordUserId   String            @map("discord_user_id")
  title           String
  description     String
  solution        String?
  category        ReportCategory?
  resolvedAt      DateTime?         @map("resolved_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  embeddings      ReportEmbedding[]

  @@index([createdAt])
  @@index([discordThreadId])
  @@map("houston_bot_reports")
}

model ReportEmbedding {
  id        BigInt   @id @default(autoincrement())
  reportId  BigInt   @unique @map("report_id")
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(1536)")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([reportId])
  @@map("houston_bot_report_embeddings")
}

enum ReportCategory {
  BUG
  CONFIG
  OTHER
}
