generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

model ModerationBan {
  id           BigInt    @id @default(autoincrement())
  guildId      String    @map("guild_id")
  userId       String    @map("user_id")
  username     String
  moderatorId  String?   @map("moderator_id")
  moderatorTag String?   @map("moderator_tag")
  reason       String
  permanent    Boolean   @default(true)
  bannedAt     DateTime  @default(now()) @map("banned_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by_id")

  @@index([guildId, bannedAt])
  @@index([guildId, userId, revokedAt])
  @@index([userId])
  @@map("houston_bot_moderation_bans")
}

model ModerationTimeout {
  id           BigInt    @id @default(autoincrement())
  guildId      String    @map("guild_id")
  userId       String    @map("user_id")
  username     String
  moderatorId  String?   @map("moderator_id")
  moderatorTag String?   @map("moderator_tag")
  reason       String
  duration     Int
  expiresAt    DateTime  @map("expires_at")
  appliedAt    DateTime  @default(now()) @map("applied_at")
  revokedAt    DateTime? @map("revoked_at")
  revokedById  String?   @map("revoked_by_id")

  @@index([guildId, appliedAt])
  @@index([guildId, expiresAt])
  @@index([userId])
  @@map("houston_bot_moderation_timeouts")
}

model ScheduledMessage {
  id             BigInt        @id @default(autoincrement())
  createdAt      DateTime      @default(now()) @map("created_at")
  guildId        String        @map("guild_id")
  channelId      String        @map("channel_id")
  messageContent String        @map("message_content")
  scheduleTime   DateTime      @map("schedule_time")
  status         MessageStatus @default(PENDING)
  title          String?
  messageUrl     String?       @map("message_url")
  imageUrl       String?       @map("image_url")
  reactions      String[]      @default([])

  @@map("houston_bot_scheduled_messages")
}

enum MessageStatus {
  PENDING
  SENT
  ERROR_SENDING
  ERROR_CHANNEL_NOT_FOUND
}

model Report {
  id              BigInt            @id @default(autoincrement())
  discordThreadId String            @unique @map("discord_thread_id")
  discordUserId   String            @map("discord_user_id")
  title           String
  description     String
  solution        String?
  category        ReportCategory?
  resolvedAt      DateTime?         @map("resolved_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")
  embeddings      ReportEmbedding[]

  @@index([createdAt])
  @@index([discordThreadId])
  @@map("houston_bot_reports")
}

model ReportEmbedding {
  id        BigInt   @id @default(autoincrement())
  reportId  BigInt   @unique @map("report_id")
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(3072)")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([reportId])
  @@map("houston_bot_report_embeddings")
}

enum ReportCategory {
  BUG
  CONFIG
  OTHER
}

// ========================================
// MODULE: Discord Metrics
// ========================================

model MetricsMember {
  id            Int       @id @default(autoincrement())
  guildId       String    @map("guild_id")
  userId        String    @map("user_id")
  username      String
  discriminator String?
  isBot         Boolean   @default(false) @map("is_bot")
  joinedAt      DateTime  @map("joined_at")
  leftAt        DateTime? @map("left_at")
  isActive      Boolean   @default(true) @map("is_active")
  nickname      String?

  @@unique([guildId, userId])
  @@index([guildId, isActive])
  @@index([isActive, leftAt])
  @@map("metrics_members")
}

model MetricsJoinLeaveEvent {
  id        Int      @id @default(autoincrement())
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  eventType String   @map("event_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@map("metrics_join_leave_events")
}

model MetricsMessageEvent {
  id            Int      @id @default(autoincrement())
  messageId     String   @unique @map("message_id")
  guildId       String   @map("guild_id")
  userId        String   @map("user_id")
  channelId     String   @map("channel_id")
  channelName   String?  @map("channel_name")
  categoryName  String?  @map("category_name")
  contentLength Int?     @map("content_length")
  hasEmbed      Boolean  @default(false) @map("has_embed")
  hasAttachment Boolean  @default(false) @map("has_attachment")
  createdAt     DateTime @map("created_at")

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@map("metrics_message_events")
}

model MetricsReactionEvent {
  id        Int      @id @default(autoincrement())
  messageId String   @map("message_id")
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  channelId String   @map("channel_id")
  emoji     String
  eventType String   @map("event_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@map("metrics_reaction_events")
}

model MetricsVoiceEvent {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  userId      String   @map("user_id")
  channelId   String?  @map("channel_id")
  channelName String?  @map("channel_name")
  eventType   String   @map("event_type")
  sessionId   String?  @map("session_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([guildId, createdAt])
  @@index([guildId, userId, createdAt])
  @@map("metrics_voice_events")
}

model MetricsActiveVoiceSession {
  guildId          String   @map("guild_id")
  userId           String   @map("user_id")
  discordSessionId String   @map("discord_session_id")
  channelId        String   @map("channel_id")
  joinTimestamp    DateTime @default(now()) @map("join_timestamp")

  @@id([guildId, userId, discordSessionId])
  @@map("metrics_active_voice_sessions")
}

model MetricsCompletedVoiceSession {
  id               Int      @id @default(autoincrement())
  guildId          String   @map("guild_id")
  userId           String   @map("user_id")
  channelId        String   @map("channel_id")
  discordSessionId String?  @map("discord_session_id")
  joinTimestamp    DateTime @map("join_timestamp")
  leaveTimestamp   DateTime @map("leave_timestamp")
  durationSeconds  Int      @map("duration_seconds")
  processedAt      DateTime @default(now()) @map("processed_at")

  @@index([guildId, userId, joinTimestamp])
  @@index([guildId, joinTimestamp])
  @@index([leaveTimestamp])
  @@map("metrics_completed_voice_sessions")
}

model MetricsReportSnapshot {
  id          Int      @id @default(autoincrement())
  guildId     String   @map("guild_id")
  reportType  String   @map("report_type") // 'daily' | 'weekly' | 'monthly'
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  data        Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([guildId, reportType, periodStart])
  @@index([guildId, reportType, createdAt])
  @@map("metrics_report_snapshots")
}
